#include <stdio.h>
#define MAX 10
typedef struct {
    int dados[MAX];
    int topo;
  
} Pilha;

void inicializar(Pilha *p) {
    p->topo = -1;
}

int estaVazia(Pilha *p) {
    return p->topo == -1;
}

int estaCheia(Pilha *p) {
    return p->topo == MAX - 1;
}

void push(Pilha *p, int valor) {
    if (estaCheia(p)) return;
    p->dados[++p->topo] = valor;
}

int pop(Pilha *p) {
    if (estaVazia(p)) return -1;
    return p->dados[p->topo--];
}

void esvaziar(Pilha *p) {
    p->topo = -1;
}
int main() {
     Pilha p;
     inicializar(&p);
     int v[] = {10, 20, 30, 40, 50, 60};
     for(int i=0; i<6; i++){
         printf("\nseu numeros são %d", v[i]);
         push(&p, v[i]);
     }
     printf("\n");
     for(int i=0; i<6; i++){
         printf("\nseus numeros invertidos são %d", v[i]);
         v[i] = pop(&p);
         
     }
}
