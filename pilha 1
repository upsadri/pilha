    scanf("%d",&numero);
    
   
    
    for(int i = 0; i < MAX; i++){
    scanf("%d", &numero);  
    original[i] = numero;
    push(&p, numero);
}
   for(int i = 0; i < numero; i++){
       printf("\nnumeros originais %d", original[i]);
       
   }
    while(!estaVazia(&p)){
         numero = pop(&p); 
        printf("numeros invertidos: %d\n", numero);
    }
}
